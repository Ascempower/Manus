{
  "name": "choice-insurance-website",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npx next dev --turbopack",
    "build": "npx next build",
    "build:dev": "SKIP_PREBUILD=true npx next build",
    "start": "npx next start",
    "lint": "npx next lint",
    "lint:fast": "npx next lint --quiet --max-warnings 10",
    "lint:fix": "npx next lint --fix",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "type-check": "tsc --noEmit",
    "type-check:fast": "tsc --noEmit --skipLibCheck",
    "prebuild": "node scripts/conditional-prebuild.js",
    "prebuild:fast": "node scripts/prebuild-parallel.js",
    "prebuild:sequential": "pnpm run lint:fast && pnpm run type-check:fast && pnpm run validate-pwa:fast",
    "prebuild:full": "node scripts/update-cache-version.js && pnpm run lint && pnpm run type-check && pnpm run validate-pwa",
    "postbuild": "pnpm run generate-critical",
    "validate-pwa": "node scripts/validate-pwa.js",
    "validate-pwa:fast": "node scripts/validate-pwa.js --fast",
    "validate-blog-images": "node scripts/validate-blog-images.js",
    "deployment-check": "node scripts/deployment-check.js",
    "test-image-fallbacks": "node scripts/test-image-fallbacks.js",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force .next, dist, out, build, .turbo -ErrorAction SilentlyContinue\"",
    "clean:all": "pnpm run clean && powershell -Command \"Remove-Item -Recurse -Force node_modules, pnpm-lock.yaml -ErrorAction SilentlyContinue\"",
    "export": "npx next build && npx next export",
    "generate-critical": "node scripts/generate-critical-css.cjs",
    "analyze": "ANALYZE=true pnpm run build",
    "build:optimize": "node scripts/build-optimize.js",
    "build:safe": "node pre-build-check.js && pnpm run clean && pnpm run build:optimize",
    "test:build": "pnpm run clean && pnpm run build",
    "deploy:preview": "pnpm run test:build && echo 'Ready for preview deployment'",
    "setup": "node scripts/setup-dev.js",
    "print-versions": "node -p \"'React: ' + require('react/package.json').version + ', Node: ' + process.version\"",
    "update-cache": "node scripts/update-cache-version.js",
    "clear-cache": "node -e \"console.log('Manual cache clearing - visit /api/version to check current version')\""
  },
  "dependencies": {
    "@arcjet/inspect": "^1.0.0-beta.8",
